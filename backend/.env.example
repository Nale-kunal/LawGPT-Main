PORT=5000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=debug

# MongoDB Atlas Connection String (REQUIRED)
# Get from: https://cloud.mongodb.com/ → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/lawgpt?retryWrites=true&w=majority

# JWT Secret for Authentication (REQUIRED — minimum 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-minimum-64-characters-change-this-in-production

# JWT Refresh Token Secret (REQUIRED — different from JWT_SECRET)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=your-jwt-refresh-secret-different-from-jwt-secret-change-this

# Cloudinary Configuration (REQUIRED for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL (for CORS and password reset emails)
FRONTEND_URL=http://localhost:5173

# Optional: SendGrid API Key (for transactional email)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# Optional: Sentry DSN (for error tracking in production)
# SENTRY_DSN=https://xxxxxxxxxxxx@o0000000.ingest.sentry.io/0000000

# Google OAuth 2.0 (Optional — leave empty to disable Google login)
# Setup: https://console.cloud.google.com/ → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Authorised redirect URI: http://localhost:5000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── Email / SMTP — Forgot Password (REQUIRED for password reset emails) ───────
# Hostinger: smtp.hostinger.com  |  Gmail: smtp.gmail.com  |  Zoho: smtp.zoho.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contact@juriq.in
SMTP_PASS=your-smtp-password-here
MAIL_FROM=contact@juriq.in

# Base URL used in the reset link sent by email (no trailing slash)
RESET_PASSWORD_BASE_URL=https://juriq.in

# Optional: Sentry DSN (for error tracking in production)
# SENTRY_DSN=https://xxxxxxxxxxxx@o0000000.ingest.sentry.io/0000000
